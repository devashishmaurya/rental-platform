# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Keycloak Configuration (Optional - leave empty to run without Keycloak)
# Uncomment and configure when Keycloak is ready:
# NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
# NEXT_PUBLIC_KEYCLOAK_REALM=rental-platform
# NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=rental-platform-client

# Node Environment
NODE_ENV=development
